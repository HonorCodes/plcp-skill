    <Text>NOP();</Text>
  </Rung>
  <Rung Number="1" Type="N">
    <Comment>PID TO CV-1 OUTPUT</Comment>
    <Text>XIC(CGTP1.Status.Running)MOV(Tertiary_TT2_PID.Out_CV,CV1_BELMIO_AO.PSet_CV);</Text>
  </Rung>
  <Rung Number="2" Type="N">
    <Comment>CV-1 CLOSE WHEN PUMP OFF</Comment>
    <Text>XIO(CGTP1.Status.Running)MOV(0,CV1_BELMIO_AO.PSet_CV);</Text>
  </Rung>
</RLLContent>
</Routine>

<!-- ============================================ -->
<!-- ALARMS                                       -->
<!-- ============================================ -->
<Routine Name="Alarms" Type="RLL">
<RLLContent>
  <Rung Number="0" Type="N">
    <Text>NOP();</Text>
  </Rung>
  <Rung Number="1" Type="N">
    <Comment>CGPP1 ALARM</Comment>
    <Text>XIC(CGPP1_MS)XIO(CGPP1_FB)XIO(CGPP1.Control.Reset)TON(CGPP1.Alarm_TMR,?,5000,0);</Text>
  </Rung>
  <Rung Number="2" Type="N">
    <Comment>CGPP1 ALARM LATCH</Comment>
    <Text>XIC(CGPP1.Alarm_TMR.DN)OTL(CGPP1.Status.Alarm);</Text>
  </Rung>
  <Rung Number="3" Type="N">
    <Comment>CGSP1 ALARM</Comment>
    <Text>XIC(CGSP1_MS)XIO(CGSP1_FB)XIO(CGSP1.Control.Reset)TON(CGSP1.Alarm_TMR,?,5000,0);</Text>
  </Rung>
  <Rung Number="4" Type="N">
    <Comment>CGSP1 ALARM LATCH</Comment>
    <Text>XIC(CGSP1.Alarm_TMR.DN)OTL(CGSP1.Status.Alarm);</Text>
  </Rung>
  <Rung Number="5" Type="N">
    <Comment>CGSP2 ALARM</Comment>
    <Text>XIC(CGSP2_MS)XIO(CGSP2_FB)XIO(CGSP2.Control.Reset)TON(CGSP2.Alarm_TMR,?,5000,0);</Text>
  </Rung>
  <Rung Number="6" Type="N">
    <Comment>CGSP2 ALARM LATCH</Comment>
    <Text>XIC(CGSP2.Alarm_TMR.DN)OTL(CGSP2.Status.Alarm);</Text>
  </Rung>
  <Rung Number="7" Type="N">
    <Comment>CGTP1 ALARM</Comment>
    <Text>XIC(CGTP1_MS)XIO(CGTP1_FB)XIO(CGTP1.Control.Reset)TON(CGTP1.Alarm_TMR,?,5000,0);</Text>
  </Rung>
  <Rung Number="8" Type="N">
    <Comment>CGTP1 ALARM LATCH</Comment>
    <Text>XIC(CGTP1.Alarm_TMR.DN)OTL(CGTP1.Status.Alarm);</Text>
  </Rung>
  <Rung Number="9" Type="N">
    <Comment>CWP1 ALARM</Comment>
    <Text>XIC(CWP1_MS)XIO(CWP1_FB)XIO(CWP1.Control.Reset)TON(CWP1.Alarm_TMR,?,5000,0);</Text>
  </Rung>
  <Rung Number="10" Type="N">
    <Comment>CWP1 ALARM LATCH</Comment>
    <Text>XIC(CWP1.Alarm_TMR.DN)OTL(CWP1.Status.Alarm);</Text>
  </Rung>
  <Rung Number="11" Type="N">
    <Comment>CT1 FAN ALARM</Comment>
    <Text>XIC(CT1_FAN_VFD.PCmd_StartFwd)XIO(CT1_FAN_VFD.Sts_RunningFwd)XIO(System.Control.Reset)TON(CT1_Fan.Alarm_TMR,?,10000,0);</Text>
  </Rung>
  <Rung Number="12" Type="N">
    <Comment>CT1 FAN ALARM LATCH</Comment>
    <Text>XIC(CT1_Fan.Alarm_TMR.DN)OTL(CT1_Fan.Status.Alarm);</Text>
  </Rung>
  <Rung Number="13" Type="N">
    <Comment>ALARM RESET — ALL DEVICES</Comment>
    <Text>XIC(System.Control.Reset)OTU(CGPP1.Status.Alarm)OTU(CGSP1.Status.Alarm)OTU(CGSP2.Status.Alarm)OTU(CGTP1.Status.Alarm)OTU(CWP1.Status.Alarm)OTU(CT1_Fan.Status.Alarm)OTU(CGSP_LL.Status.Alarm);</Text>
  </Rung>
</RLLContent>
</Routine>

</Routines>
</Program>

</Programs>

</Controller>

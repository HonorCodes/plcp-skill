<!-- ============================================ -->
<!-- CW BYPASS — CONDENSER WATER BYPASS           -->
<!-- ============================================ -->
<Routine Name="CW_Bypass_Ctrl" Type="RLL">
<RLLContent>
  <Rung Number="0" Type="N">
    <Text>NOP();</Text>
  </Rung>
  <Rung Number="1" Type="N">
    <Comment>BYPASS CONDITION — FAN OFF AND CW TOO COLD</Comment>
    <Text>XIO(CT1_Fan.Status.Running)LES(CW_TT.Val,System.SP.CW_Temp_Min)OTE(CW_Bypass.Bypass_Active);</Text>
  </Rung>
  <Rung Number="2" Type="N">
    <Comment>CLOSE TOWER INLET VALVE</Comment>
    <Text>XIC(CW_Bypass.Bypass_Active)OTE(CG_MCV2.PCmd_Close);</Text>
  </Rung>
  <Rung Number="3" Type="N">
    <Comment>OPEN BYPASS VALVE</Comment>
    <Text>XIC(CW_Bypass.Bypass_Active)OTE(CG_MCV3.PCmd_Open);</Text>
  </Rung>
  <Rung Number="4" Type="N">
    <Comment>NORMAL OPERATION — CLOSE BYPASS</Comment>
    <Text>XIO(CW_Bypass.Bypass_Active)OTE(CG_MCV3.PCmd_Close);</Text>
  </Rung>
</RLLContent>
</Routine>

<!-- ============================================ -->

<!-- ============================================ -->
<!-- CGSP LEAD/LAG + DP PID                       -->
<!-- ============================================ -->
<Routine Name="CGSP_LeadLag" Type="RLL">
<RLLContent>
  <Rung Number="0" Type="N">
    <Text>NOP();</Text>
  </Rung>
  <Rung Number="1" Type="N">
    <Comment>WEEKLY LEAD ROTATION TIMER</Comment>
    <Text>TON(CGSP_LL.Rotation_TMR,?,604800000,0);</Text>
  </Rung>
  <Rung Number="2" Type="N">
    <Comment>TOGGLE LEAD ON TIMER DONE</Comment>
    <Text>[XIC(CGSP_LL.Rotation_TMR.DN)XIO(CGSP_LL.Lead_Is_SP1)OTL(CGSP_LL.Lead_Is_SP1),XIC(CGSP_LL.Rotation_TMR.DN)XIC(CGSP_LL.Lead_Is_SP1)OTU(CGSP_LL.Lead_Is_SP1)];</Text>
  </Rung>
  <Rung Number="3" Type="N">
    <Comment>RESET ROTATION TIMER</Comment>
    <Text>XIC(CGSP_LL.Rotation_TMR.DN)RES(CGSP_LL.Rotation_TMR);</Text>
  </Rung>
  <Rung Number="4" Type="N">
    <Comment>LEAD PUMP ASSIGNMENT</Comment>
    <Text>[XIC(CGSP_LL.Lead_Is_SP1)OTE(CGSP_LL.CGSP1_Is_Lead),XIO(CGSP_LL.Lead_Is_SP1)OTE(CGSP_LL.CGSP2_Is_Lead)];</Text>
  </Rung>
  <Rung Number="5" Type="N">
    <Comment>LEAD PUMP START</Comment>
    <Text>XIC(CH1.Status.Running)[XIC(CGSP_LL.CGSP1_Is_Lead)XIC(CGSP1.Status.Permissives_OK)OTE(CGSP1.Control.Start_Req),XIC(CGSP_LL.CGSP2_Is_Lead)XIC(CGSP2.Status.Permissives_OK)OTE(CGSP2.Control.Start_Req)];</Text>
  </Rung>
  <Rung Number="6" Type="N">
    <Comment>LAG PUMP ENABLE — HIGH DP DEMAND</Comment>
    <Text>GRT(CGSP_DP_PID.Out_CV,CGSP_LL.Lag_Enable_SP)OTE(CGSP_LL.Lag_Enable);</Text>
  </Rung>
  <Rung Number="7" Type="N">
    <Comment>LAG PUMP START</Comment>
    <Text>XIC(CGSP_LL.Lag_Enable)[XIC(CGSP_LL.CGSP2_Is_Lead)XIC(CGSP1.Status.Permissives_OK)OTE(CGSP1.Control.Start_Req),XIC(CGSP_LL.CGSP1_Is_Lead)XIC(CGSP2.Status.Permissives_OK)OTE(CGSP2.Control.Start_Req)];</Text>
  </Rung>
  <Rung Number="8" Type="N">
    <Comment>DP PID TO SPEED REFERENCE</Comment>
    <Text>MOV(CGSP_DP_PID.Out_CV,CGSP_LL.Speed_Ref);</Text>
  </Rung>
  <Rung Number="9" Type="N">
    <Comment>SPEED MATCHING — CGSP1</Comment>
    <Text>XIC(CGSP1.Status.Running)MOV(CGSP_LL.Speed_Ref,CGSP1_VFD.PSet_SpeedRef);</Text>
  </Rung>
  <Rung Number="10" Type="N">
    <Comment>SPEED MATCHING — CGSP2</Comment>
    <Text>XIC(CGSP2.Status.Running)MOV(CGSP_LL.Speed_Ref,CGSP2_VFD.PSet_SpeedRef);</Text>
  </Rung>
  <Rung Number="11" Type="N">
    <Comment>LAG PUMP DISABLE — LOW DP DEMAND</Comment>
    <Text>LES(CGSP_DP_PID.Out_CV,CGSP_LL.Lag_Disable_SP)OTU(CGSP_LL.Lag_Enable);</Text>
  </Rung>
  <Rung Number="12" Type="N">
    <Comment>LAG PUMP STOP</Comment>
    <Text>XIO(CGSP_LL.Lag_Enable)[XIC(CGSP_LL.CGSP2_Is_Lead)OTE(CGSP1.Control.Stop_Cmd),XIC(CGSP_LL.CGSP1_Is_Lead)OTE(CGSP2.Control.Stop_Cmd)];</Text>
  </Rung>
  <Rung Number="13" Type="N">
    <Comment>BOTH PUMPS FAULTED ALARM</Comment>
    <Text>XIC(CGSP1.Status.Faulted)XIC(CGSP2.Status.Faulted)OTL(CGSP_LL.Status.Alarm);</Text>
  </Rung>
</RLLContent>
</Routine>


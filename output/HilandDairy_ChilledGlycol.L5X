<!-- PROGRAMS                                     -->
<!-- ============================================ -->
<Programs>

<!-- ============================================ -->
<!-- PROCESS CONTROL PROGRAM                      -->
<!-- ============================================ -->
<Program Name="Process_Control" Type="Normal"
  Description="Chilled Glycol System Process Control">

<Tags>
  <!-- Program-scoped tags can be added here -->
</Tags>

<Routines>

<!-- Main Dispatcher -->
<Routine Name="Main" Type="RLL">
<RLLContent>
  <Rung Number="0" Type="N">
    <Comment>Safety Interlocks</Comment>
    <Text>JSR(Safety_Interlocks,0);</Text>
  </Rung>
  <Rung Number="1" Type="N">
    <Comment>Chiller Control</Comment>
    <Text>JSR(Chiller_Control,0);</Text>
  </Rung>
  <Rung Number="2" Type="N">
    <Comment>Primary Pump</Comment>
    <Text>JSR(CGPP1_Ctrl,0);</Text>
  </Rung>
  <Rung Number="3" Type="N">
    <Comment>Condenser Water Pump</Comment>
    <Text>JSR(CWP1_Ctrl,0);</Text>
  </Rung>
  <Rung Number="4" Type="N">
    <Comment>Secondary Pump 1</Comment>
    <Text>JSR(CGSP1_Ctrl,0);</Text>
  </Rung>
  <Rung Number="5" Type="N">
    <Comment>Secondary Pump 2</Comment>
    <Text>JSR(CGSP2_Ctrl,0);</Text>
  </Rung>
  <Rung Number="6" Type="N">
    <Comment>Secondary Pump Lead/Lag</Comment>
    <Text>JSR(CGSP_LeadLag,0);</Text>
  </Rung>
  <Rung Number="7" Type="N">
    <Comment>Tertiary Pump</Comment>
    <Text>JSR(CGTP1_Ctrl,0);</Text>
  </Rung>
  <Rung Number="8" Type="N">
    <Comment>Cooling Tower Fan</Comment>
    <Text>JSR(CT1_Fan_Ctrl,0);</Text>
  </Rung>
  <Rung Number="9" Type="N">
    <Comment>CW Bypass</Comment>
    <Text>JSR(CW_Bypass_Ctrl,0);</Text>
  </Rung>
  <Rung Number="10" Type="N">
    <Comment>Tertiary CV-1 PID</Comment>
    <Text>JSR(Tertiary_CV1,0);</Text>
  </Rung>
  <Rung Number="11" Type="N">
    <Comment>Alarms</Comment>
    <Text>JSR(Alarms,0);</Text>
  </Rung>
</RLLContent>
</Routine>

<!-- ============================================ -->
<!-- SAFETY INTERLOCKS                            -->
<!-- ============================================ -->
<Routine Name="Safety_Interlocks" Type="RLL">
<RLLContent>
  <Rung Number="0" Type="N">
    <Text>NOP();</Text>
  </Rung>
  <Rung Number="1" Type="N">
    <Comment>CT-1 VIBRATION CUTOUT</Comment>
    <Text>[XIC(CT1_VIB_CO_SW)OTL(Safety.CT1_Vib_Trip),XIC(System.Control.Reset)OTU(Safety.CT1_Vib_Trip)];</Text>
  </Rung>
  <Rung Number="2" Type="N">
    <Comment>CT-1 FAN INTERLOCK</Comment>
    <Text>XIO(Safety.CT1_Vib_Trip)OTE(Safety.CT1_Fan_OK);</Text>
  </Rung>
  <Rung Number="3" Type="N">
    <Comment>CHILLER FLOW PERMISSIVE</Comment>
    <Text>XIC(CG_MCV1.Sts_Opened)XIC(CG_MCV2.Sts_Opened)OTE(Safety.CH1_Flow_OK);</Text>
  </Rung>
  <Rung Number="4" Type="N">
    <Comment>CHILLER ENABLE PERMISSIVE</Comment>
    <Text>XIC(Safety.CH1_Flow_OK)XIC(CGPP1.Status.Running)XIC(CWP1.Status.Running)OTE(Safety.CH1_Enable_OK);</Text>
  </Rung>
  <Rung Number="5" Type="N">
    <Comment>CHILLER FAULT TRIP</Comment>
    <Text>[XIC(CH1.Status.Faulted)OTL(Safety.CH1_Fault_Trip),XIC(System.Control.Reset)OTU(Safety.CH1_Fault_Trip)];</Text>
  </Rung>
  <Rung Number="6" Type="N">
    <Comment>CHILLER CASCADE INTERLOCK</Comment>
    <Text>XIO(Safety.CH1_Fault_Trip)XIC(Safety.CH1_Enable_OK)OTE(Safety.CH1_Run_OK);</Text>
  </Rung>
  <Rung Number="7" Type="N">
    <Comment>SYSTEM GLOBAL RESET</Comment>
    <Text>XIC(System.Control.HMI_Reset_PB)OTE(System.Control.Reset);</Text>
  </Rung>
</RLLContent>
</Routine>

<!-- ============================================ -->
<!-- CHILLER CONTROL                              -->
<!-- ============================================ -->
<Routine Name="Chiller_Control" Type="RLL">
<RLLContent>
  <Rung Number="0" Type="N">
    <Text>NOP();</Text>
  </Rung>
  <Rung Number="1" Type="N">
    <Comment>CAPACITY CONTROL — CHILLER ENABLE</Comment>
    <Text>GRT(TT1_GLYCOL.Val,System.SP.ChilledGlycol_Temp)OTE(CH1.Control.Start_Req);</Text>
  </Rung>
  <Rung Number="2" Type="N">
    <Comment>CHILLER START — STEP 1: OPEN CW ISOLATION</Comment>
    <Text>XIC(CH1.Control.Start_Req)XIC(Safety.CH1_Run_OK)OTE(CG_MCV1.PCmd_Open);</Text>
  </Rung>
  <Rung Number="3" Type="N">
    <Comment>CHILLER START — STEP 2: OPEN CT INLET</Comment>
    <Text>XIC(CH1.Control.Start_Req)XIC(Safety.CH1_Run_OK)OTE(CG_MCV2.PCmd_Open);</Text>
  </Rung>
  <Rung Number="4" Type="N">
    <Comment>CHILLER START — STEP 3: START PRIMARY PUMP</Comment>
    <Text>XIC(CH1.Control.Start_Req)XIC(Safety.CH1_Run_OK)XIC(CG_MCV1.Sts_Opened)OTE(CGPP1.Control.Start_Req);</Text>
  </Rung>
  <Rung Number="5" Type="N">
    <Comment>CHILLER START — STEP 4: START CW PUMP</Comment>
    <Text>XIC(CH1.Control.Start_Req)XIC(Safety.CH1_Run_OK)XIC(CG_MCV1.Sts_Opened)OTE(CWP1.Control.Start_Req);</Text>
  </Rung>
  <Rung Number="6" Type="N">
    <Comment>CHILLER START — STEP 5: ENABLE CHILLER</Comment>
    <Text>XIC(CH1.Control.Start_Req)XIC(Safety.CH1_Run_OK)XIC(CGPP1.Status.Running)XIC(CWP1.Status.Running)OTE(CH1.Control.Start_Cmd);</Text>
  </Rung>
  <Rung Number="7" Type="N">
    <Comment>CHILLER SHUTDOWN SEQUENCE</Comment>
    <Text>XIO(CH1.Control.Start_Req)XIC(CH1.Status.Running)OTE(CH1.Control.Stop_Cmd);</Text>
  </Rung>
  <Rung Number="8" Type="N">
    <Comment>CHILLER SHUTDOWN — STOP ASSOCIATED</Comment>
    <Text>XIO(CH1.Control.Start_Req)XIO(CH1.Status.Running)OTE(CGPP1.Control.Stop_Cmd)OTE(CWP1.Control.Stop_Cmd)OTE(CG_MCV1.PCmd_Close)OTE(CG_MCV2.PCmd_Close);</Text>
  </Rung>
  <Rung Number="9" Type="N">
    <Comment>CHILLER RUNNING STATUS</Comment>
    <Text>XIC(CH1_FB)OTE(CH1.Status.Running);</Text>
  </Rung>
</RLLContent>
</Routine>

<!-- ============================================ -->
<!-- CGPP1 — PRIMARY PUMP                         -->
<!-- ============================================ -->
<Routine Name="CGPP1_Ctrl" Type="RLL">
<RLLContent>
  <Rung Number="0" Type="N">
    <Text>NOP();</Text>
  </Rung>
  <Rung Number="1" Type="N">
    <Comment>AUTO / MANUAL SELECTION</Comment>
    <Text>[XIC(CGPP1.Control.Auto_PB),XIO(CGPP1.Control.Manual_PB)]OTE(CGPP1.Status.Auto);</Text>
  </Rung>
  <Rung Number="2" Type="N">
    <Comment>AUTO / MANUAL INVERSE</Comment>
    <Text>XIO(CGPP1.Status.Auto)OTE(CGPP1.Status.Manual);</Text>
  </Rung>
  <Rung Number="3" Type="N">
    <Comment>FAULT RESET</Comment>
    <Text>[XIC(CGPP1.Control.HMI_Reset_PB),XIC(System.Control.Reset)]OTE(CGPP1.Control.Reset);</Text>
  </Rung>
  <Rung Number="4" Type="N">
    <Comment>FAULT HANDLING</Comment>
    <Text>[XIC(CGPP1.Control.Start_Req)XIC(CGPP1.Status.Permissives_OK),XIC(CGPP1.Control.Manual_Start)]XIO(CGPP1.Status.Running)XIO(CGPP1.Status.Faulted)XIO(CGPP1.Control.Reset)TON(CGPP1.Fault_TMR,?,10000,0);</Text>
  </Rung>
  <Rung Number="5" Type="N">
    <Comment>FAULT HANDLING — SET FAULTED</Comment>
    <Text>XIC(CGPP1.Fault_TMR.DN)OTE(CGPP1.Status.Faulted);</Text>
  </Rung>
  <Rung Number="6" Type="N">
    <Comment>PERMISSIVES</Comment>
    <Text>XIO(CGPP1.Status.Faulted)OTE(CGPP1.Status.Permissives_OK);</Text>
  </Rung>
  <Rung Number="7" Type="N">
    <Comment>MANUAL START / STOP</Comment>
    <Text>[XIC(CGPP1.Status.Manual)XIC(CGPP1.Control.HMI_Start_PB),XIO(CGPP1.Control.Stop_Cmd)XIC(CGPP1.Control.Manual_Start)]OTE(CGPP1.Control.Manual_Start);</Text>
  </Rung>
  <Rung Number="8" Type="N">
    <Comment>AUTO START / STOP</Comment>
